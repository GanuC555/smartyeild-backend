# App
PORT=3001
NODE_ENV=development
DEMO_MODE=true
CHAIN_ADAPTER=stub

# Database — use docker-compose.yml for local dev
MONGODB_URI=mongodb://localhost:27017/smartyield
REDIS_URL=redis://localhost:6379

# JWT — CHANGE IN PRODUCTION
JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AI — set ONE of the following (checked in order: Anthropic → OpenRouter → OpenAI → custom)
# Anthropic Claude  →  console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# OpenRouter (free tier)  →  openrouter.ai
# OPENROUTER_API_KEY=sk-or-...
# OpenAI  →  platform.openai.com
# OPENAI_API_KEY=sk-...
# Generic OpenAI-compatible (Gemini, Ollama, Together, etc.)
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=your_key_here
# Override model name for any provider (optional)
# LLM_MODEL=gemini-1.5-flash

# Telegram — get from @BotFather on Telegram (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# URL of your frontend app — used for payment deep-links sent via Telegram bot
FRONTEND_URL=https://5b08-2409-40e6-24d-27ab-a9b1-9ca-1dbf-1e18.ngrok-free.app

# OneChain Testnet
ONECHAIN_RPC_URL=https://rpc-testnet.onelabs.cc
ONECHAIN_PACKAGE_ID=
ONECHAIN_VAULT_OBJECT_ID=
ONECHAIN_SPEND_BUFFER_OBJECT_ID=
ONECHAIN_LANE_ROUTER_OBJECT_ID=
ONECHAIN_ADMIN_PRIVATE_KEY=
