# App
PORT=3001
NODE_ENV=development
DEMO_MODE=true
CHAIN_ADAPTER=stub

# Database — use docker-compose.yml for local dev
MONGODB_URI=mongodb://localhost:27017/smartyield
REDIS_URL=redis://localhost:6379

# JWT — CHANGE IN PRODUCTION
JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AI — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Telegram — get from @BotFather on Telegram (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OneChain
ONECHAIN_RPC_URL=https://rpc.testnet.onechain.xyz
VAULT_CONTRACT_ADDRESS=0x...
